{
  "permissions": {
    "allow": [
      "Bash(bundle install)",
      "Bash(bundle exec rspec:*)",
      "Bash(bundle exec rake:*)",
      "Bash(bundle exec rubocop:*)",
      "Bash(gem build:*)",
      "Bash(ruby -e:*)",
      "Bash(ruby --version)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git stash:*)",
      "Bash(git checkout:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git reset:*)",
      "Bash(gh pr:*)",
      "Bash(gh api:*)"
    ],
    "deny": [
      "Read(./.env*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/post-edit-lint.sh"
          }
        ]
      }
    ]
  }
}
